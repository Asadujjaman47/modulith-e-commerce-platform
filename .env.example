# Template for the local .env consumed by `docker compose`.
# Copy to .env and adjust values:  cp .env.example .env

# ---- Spring ----
SPRING_PROFILES_ACTIVE=docker

# ---- PostgreSQL container (the postgres image requires POSTGRES_*) ----
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# ---- Application datasource (DB_* scheme; used when running the app locally,
#      e.g. IntelliJ / `mvn spring-boot:run`. In docker these are derived from POSTGRES_*) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USERNAME=ecommerce
DB_PASSWORD=change-me

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Application ----
APP_PORT=8080

# ---- Monitoring ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# ---- Mailpit ----
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025