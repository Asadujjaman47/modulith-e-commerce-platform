# Template for the local .env consumed by `docker compose`.
# Copy to .env and adjust values:  cp .env.example .env

# ---- Spring ----
SPRING_PROFILES_ACTIVE=docker

# ---- PostgreSQL container (the postgres image requires POSTGRES_*) ----
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# ---- Application datasource (DB_* scheme; used when running the app locally,
#      e.g. IntelliJ / `mvn spring-boot:run`. In docker these are derived from POSTGRES_*) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USERNAME=ecommerce
DB_PASSWORD=change-me

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- JWT (Auth) ----
# Base64-encoded HMAC-SHA256 secret, >= 32 bytes. This is a PUBLIC dev placeholder — generate your
# own per environment and NEVER reuse it in production:  openssl rand -base64 48
JWT_SECRET=ZGV2LXNlY3JldC1jaGFuZ2UtbWUtYXQtbGVhc3QtMzItYnl0ZXMtbG9uZyE=
# ISO-8601 durations
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P7D

# ---- Application ----
APP_PORT=8080

# ---- Monitoring / Observability ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
# Distributed tracing (Zipkin). Sample rate 0.0–1.0; lower it in production.
ZIPKIN_PORT=9411
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans
TRACING_SAMPLE_RATE=1.0

# ---- Mailpit ----
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025