{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["ecommerce", "jvm"],
  "title": "E-Commerce — JVM & System",
  "uid": "ecommerce-jvm",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_memory_used_bytes{application=\"ecommerce\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "title": "JVM Heap Used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\", instance=~\"$instance\"})",
          "legendFormat": "heap used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{area=\"heap\", instance=~\"$instance\"})",
          "legendFormat": "heap max",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Non-Heap Used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"nonheap\", instance=~\"$instance\"})",
          "legendFormat": "nonheap used",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Live Threads",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{instance=~\"$instance\"}",
          "legendFormat": "live",
          "refId": "A"
        }
      ]
    },
    {
      "title": "GC Pause Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Process CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "expr": "process_cpu_usage{instance=~\"$instance\"}",
          "legendFormat": "process",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{instance=~\"$instance\"}",
          "legendFormat": "system",
          "refId": "B"
        }
      ]
    }
  ]
}
